---
const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-24 border-t border-white/10">
  <div class="mx-auto max-w-6xl px-4 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <span class="inline-block w-2 h-2 bg-accent-lime"></span>
      <span class="font-mono text-xs uppercase tracking-[0.25em] text-white/50">
        {year} — hecho por filipaovfx
      </span>
    </div>
    <div class="flex items-center gap-3 text-sm font-mono">
      <a href="https://github.com/filipaovfx" class="px-3 py-1.5 border border-white/20 hover:border-accent-lime hover:text-accent-lime transition">GitHub</a>
      <a href="https://linkedin.com" class="px-3 py-1.5 border border-white/20 hover:border-accent-electric hover:text-accent-electric transition">LinkedIn</a>
      <a href="mailto:juanku2003@gmail.com" class="px-3 py-1.5 border border-white/20 hover:border-accent-magenta hover:text-accent-magenta transition">Email</a>
    </div>
  </div>
</footer>

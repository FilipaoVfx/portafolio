---
import Base from '@/layouts/Base.astro';
import Hero from '@/components/Hero.tsx';
import TimelineGraph from '@/components/TimelineGraph.tsx';
import ProjectCard from '@/components/ProjectCard.tsx';
import HowIThink from '@/components/HowIThink.astro';
import Contact from '@/components/Contact.astro';
import { projects } from '@/data/projects';

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const assetPath = (path: string) => `${baseUrl}${path.replace(/^\/+/, '')}`;
---

<Base>
  <Hero />

  <TimelineGraph projects={projects} />

  <section id="projects" class="relative py-28 md:py-36 scroll-mt-24">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 md:px-12 lg:px-14">
      <div class="mb-14 md:mb-20">
        <div class="label-mono">/ proyectos</div>
        <h2 class="heading-display text-3xl md:text-5xl mt-3">Sistemas, no demos.</h2>
        <p class="mt-4 text-white/60 max-w-xl text-lg">
          Tres proyectos. Tres decisiones. Cada uno resuelve un problema real
          con arquitectura intencional.
        </p>
      </div>

      <div class="flex flex-col gap-24 md:gap-32">
        {projects.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>
    </div>
  </section>

  <HowIThink />

  <section id="quien-soy" class="relative py-28 md:py-36 scroll-mt-24 overflow-hidden">
    <div class="absolute inset-x-0 top-16 h-px bg-gradient-to-r from-transparent via-accent-lime/50 to-transparent"></div>
    <div class="mx-auto max-w-6xl px-6 sm:px-8 md:px-12 lg:px-14">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-5">
          <div class="label-mono">/ quién soy</div>
          <h2 class="heading-display text-4xl md:text-6xl mt-3 leading-tight">
            De creador visual a constructor de sistemas.
          </h2>
          <p class="mt-6 text-white/70 text-lg leading-relaxed">
            El origen de <span class="text-accent-lime font-semibold">VFX</span>
            no es solo estético: fue mi punto de entrada a detectar problemas,
            vender una solución y entender que una buena idea necesita criterio
            técnico para convertirse en producto.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="relative glass-strong border-2 border-white/15 rounded-lg p-6 md:p-8 shadow-brutal-lg overflow-hidden">
            <div class="absolute inset-0 opacity-25 pointer-events-none bg-[linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:28px_28px]"></div>
            <div class="relative grid gap-4 sm:grid-cols-3">
              <div class="brutal-dark p-5">
                <div class="label-mono text-accent-lime/80">inicio</div>
                <div class="heading-display text-4xl mt-3 text-accent-lime">15</div>
                <p class="mt-3 text-sm text-white/70 leading-relaxed">
                  Primer negocio de edición de video, nacido de una necesidad
                  clara en mi entorno.
                </p>
              </div>
              <div class="brutal-dark p-5">
                <div class="label-mono text-accent-electric/80">choque</div>
                <div class="heading-display text-4xl mt-3 text-accent-electric">fallé</div>
                <p class="mt-3 text-sm text-white/70 leading-relaxed">
                  Intenté construir algo más grande sin la base técnica
                  suficiente. La idea no era el cuello de botella.
                </p>
              </div>
              <div class="brutal-dark p-5">
                <div class="label-mono text-accent-magenta/80">giro</div>
                <div class="heading-display text-4xl mt-3 text-accent-magenta">sistemas</div>
                <p class="mt-3 text-sm text-white/70 leading-relaxed">
                  Ese intento me expuso temprano a producto, arquitectura y
                  aprendizaje autodidacta.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-12">
        <div class="lg:col-span-7 glass-strong border border-white/15 rounded-lg p-6 md:p-8">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
            <div class="relative shrink-0 w-24 h-24 border-2 border-black bg-accent-lime shadow-brutal">
              <img
                src={assetPath('/profile.jpg')}
                alt="Juan Felipe González"
                class="absolute inset-0 h-full w-full object-cover grayscale contrast-110"
                loading="lazy"
              />
            </div>
            <div class="space-y-5 text-white/72 text-base md:text-lg leading-relaxed">
              <p>
                Empecé como VFX porque a los 15 años (2019) monté mi primer
                negocio de edición de video. No tenía ni idea de lo que estaba
                haciendo, solo veía un problema en el entorno donde me movía y
                quise resolverlo.
              </p>
              <p>
                Intenté armar algo parecido a una startup... y fallé. Sabía un
                poco de HTML, algo de JS, pero no era suficiente.
              </p>
              <p>
                Pero ahí fue donde todo cambió.
              </p>
              <p>
                Me di cuenta de que no había fallado realmente: había abierto una
                puerta. Una puerta a un universo gigante de posibilidades.
              </p>
              <p>
                Desde ahí entré en una obsesión: entender cómo construir cosas,
                cómo funcionan los sistemas, cómo pasar de una idea a algo real.
              </p>
              <p>
                Podcasts, cursos, código, experimentos... todo sumaba.
              </p>
              <p>
                Hoy esa curiosidad se convirtió en algo más serio: una obsesión
                por diseñar soluciones y sistemas que todavía ni siquiera existen
                del todo.
              </p>
            </div>
          </div>
        </div>

        <aside class="lg:col-span-5">
          <div class="h-full border-2 border-black bg-ink-900 p-5 md:p-6 shadow-brutal-lg">
            <div class="flex items-center justify-between border-b border-white/10 pb-4">
              <div>
                <div class="label-mono">/ hoy</div>
                <h3 class="heading-display text-2xl mt-2 text-white">
                  Impulso convertido en método.
                </h3>
              </div>
              <span class="w-3 h-3 bg-accent-lime border-2 border-black animate-pulse-glow"></span>
            </div>

            <div class="mt-6 space-y-3">
              {[
                ['entrada', 'visual + negocio'],
                ['aprendizaje', 'producto + código'],
                ['criterio', 'arquitectura + performance'],
                ['salida', 'sistemas funcionales'],
              ].map(([label, value]) => (
                <div class="flex items-center justify-between gap-4 glass px-4 py-3">
                  <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/45">
                    {label}
                  </span>
                  <span class="font-mono text-xs text-accent-lime text-right">
                    {value}
                  </span>
                </div>
              ))}
            </div>

            <p class="mt-6 text-white/75 leading-relaxed">
              Hoy mi enfoque es claro: diseñar y construir sistemas que convierten
              ideas complejas en productos funcionales.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Contact />
</Base>

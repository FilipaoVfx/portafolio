---
const baseUrl = import.meta.env.BASE_URL;
const sectionPath = (id: string) => `${baseUrl}#${id}`;

const links = [
  { href: sectionPath('workflow'), label: 'Workflow' },
  { href: sectionPath('projects'), label: 'Proyectos' },
  { href: sectionPath('how-i-think'), label: 'How I Think' },
  { href: sectionPath('contact'), label: 'Contacto' },
];
---

<header class="sticky top-0 z-50">
  <div class="mx-auto max-w-6xl px-4 pt-4">
    <nav class="glass-strong flex items-center justify-between px-4 py-3 rounded-lg border-2 border-white/15 shadow-brutal">
      <a href={baseUrl} class="flex items-center gap-2 group">
        <span class="inline-block w-3 h-3 bg-accent-lime border border-black animate-pulse-glow"></span>
        <span class="font-display font-bold tracking-tight text-lg">filipao<span class="text-accent-lime">vfx</span></span>
      </a>
      <ul class="hidden md:flex items-center gap-1">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="px-3 py-1.5 text-sm font-mono uppercase tracking-wider text-white/70 hover:text-white hover:bg-white/5 rounded transition"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
      <a href={sectionPath('contact')} class="hidden md:inline-flex items-center gap-2 px-3 py-1.5 text-xs font-mono font-bold uppercase tracking-wider border-2 border-black bg-accent-lime text-ink-950 shadow-[3px_3px_0_0_#000] hover:translate-x-[-1px] hover:translate-y-[-1px] hover:shadow-[5px_5px_0_0_#000] transition-transform">
        Hire me →
      </a>
    </nav>
  </div>
</header>

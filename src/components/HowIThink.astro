---
const principles = [
  {
    n: '01',
    title: 'Sistemas, no funcionalidades sueltas',
    body: 'Una funcionalidad aislada es un parche. Un sistema bien diseñado absorbe nuevas piezas sin reescribirse.',
    accent: 'lime',
  },
  {
    n: '02',
    title: 'Rendimiento es producto',
    body: 'Cada 100ms de latencia es una decisión de experiencia. La velocidad no es optimización: es parte del producto.',
    accent: 'electric',
  },
  {
    n: '03',
    title: 'Decisiones > demos',
    body: 'Cualquiera clona un tutorial. Lo que importa es por qué elegiste este stack y descartaste otros.',
    accent: 'magenta',
  },
  {
    n: '04',
    title: 'Pensar desde el edge',
    body: 'Estático + edge supera a SSR continuo en la mayoría de casos. Optimiza para distribución, no para servidor.',
    accent: 'amber',
  },
];

const accentClass = {
  lime: 'text-accent-lime',
  electric: 'text-accent-electric',
  magenta: 'text-accent-magenta',
  amber: 'text-accent-amber',
};
---

<section id="how-i-think" class="relative py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mb-12">
      <div class="label-mono">/ cómo pienso</div>
      <h2 class="heading-display text-3xl md:text-5xl mt-3 max-w-2xl">
        Principios que guían cada decisión técnica.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {principles.map((p) => (
        <div class="group brutal-dark p-6 md:p-8 hover:border-white transition relative overflow-hidden">
          <div class="absolute -right-4 -top-4 font-display text-[120px] leading-none font-bold text-white/5 group-hover:text-white/10 transition select-none">
            {p.n}
          </div>
          <div class={`relative font-mono text-xs uppercase tracking-[0.3em] ${accentClass[p.accent as keyof typeof accentClass]}`}>
            principio · {p.n}
          </div>
          <h3 class="relative heading-display text-2xl mt-3">{p.title}</h3>
          <p class="relative mt-3 text-white/70 leading-relaxed text-sm">
            {p.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

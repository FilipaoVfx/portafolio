---
import Base from '@/layouts/Base.astro';
import Hero from '@/components/Hero.tsx';
import TimelineGraph from '@/components/TimelineGraph.tsx';
import ProjectCard from '@/components/ProjectCard.tsx';
import HowIThink from '@/components/HowIThink.astro';
import Contact from '@/components/Contact.astro';
import { projects } from '@/data/projects';
---

<Base>
  <Hero />

  <TimelineGraph projects={projects} />

  <section id="projects" class="relative py-28 md:py-36 scroll-mt-24">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 md:px-12 lg:px-14">
      <div class="mb-14 md:mb-20">
        <div class="label-mono">/ proyectos</div>
        <h2 class="heading-display text-3xl md:text-5xl mt-3">Sistemas, no demos.</h2>
        <p class="mt-4 text-white/60 max-w-xl text-lg">
          Tres proyectos. Tres decisiones. Cada uno resuelve un problema real
          con arquitectura intencional.
        </p>
      </div>

      <div class="flex flex-col gap-24 md:gap-32">
        {projects.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>
    </div>
  </section>

  <HowIThink />

  <section id="quien-soy" class="relative py-24 scroll-mt-24">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 md:px-12 lg:px-14">
      <div class="grid gap-8 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-4">
          <div class="label-mono">/ quién soy</div>
          <h2 class="heading-display text-3xl md:text-5xl mt-3">
            En construcción.
          </h2>
        </div>
        <div class="lg:col-span-8 glass-strong border-2 border-white/15 rounded-lg p-6 md:p-8 shadow-brutal">
          <p class="text-white/70 text-lg leading-relaxed">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer
            vitae justo sed lorem fermentum facilisis. Proin non sem at nibh
            posuere gravida. Esta sección quedará reservada para una narrativa
            más personal sobre criterio técnico, trayectoria y forma de trabajo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Contact />
</Base>

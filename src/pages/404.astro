---
import Base from '@/layouts/Base.astro';

const homePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base title="404 — FilipaoVfx" description="Página no encontrada">
  <section class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="text-center max-w-xl">
      <div class="font-display font-bold text-[140px] md:text-[200px] leading-none text-accent-lime select-none">
        404
      </div>
      <h1 class="heading-display text-2xl md:text-3xl mt-2">Nodo no encontrado.</h1>
      <p class="mt-4 text-white/60">
        La ruta que buscas no existe en el grafo. Vuelve al flujo principal.
      </p>
      <a href={homePath} class="btn-brutal mt-8">← volver al inicio</a>
    </div>
  </section>
</Base>
